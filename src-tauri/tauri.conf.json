{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gosh-Fetch",
  "version": "../package.json",
  "identifier": "com.gosh.fetch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gosh-Fetch",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "name": "BitTorrent File",
        "description": "BitTorrent metadata file",
        "mimeType": "application/x-bittorrent",
        "role": "Viewer"
      }
    ],
    "linux": {
      "deb": {
        "section": "net"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/goshitsarch-eng/Gosh-Fetch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyMzIyMzJEMEEzNDFEQzUKUldURkhUUUtMU015Y2tTNmdjUnlRR29DSE91M3JhTlRnRkxHUFVDazFuZGlWby9Eajk5a1ZUTXYK"
    }
  }
}
